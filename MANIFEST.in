include README.md
include LICENSE
include CONTRIBUTING.md
include SECURITY.md
include SUPPORT.md
include install.sh
include install.bat
include Dockerfile
include docker-compose.yml
include requirements.txt
include requirements-optional.txt
include docs/ROADMAP.md
include docs/RELEASE.md
include docs/PROJECT_BOARD.md
include docs/DEMO_SCRIPT.md
include docs/LAUNCH_KIT.md
include docs/BENCHMARK_BRIEF.md
include docs/benchmark-dashboard.html
include docs/data/leaderboard-status.json
include docs/CHROMA_MIGRATION.md
include docs/OBSERVABILITY.md
include docs/RU_LAUNCH_POSTS.md
include docs/USE_CASES.md
include docs/assets/benchmark-summary.svg
include docs/assets/wavemind-social-card.svg
include docs/assets/wavemind-demo.gif
include benchmarks/*.py
include benchmarks/*.json
include benchmarks/*.md
include examples/*.py
recursive-include examples/observability *
recursive-include examples/production-index-profile *
recursive-include examples/qdrant-sharded-streaming *
recursive-include deploy/helm/wavemind *
recursive-include deploy/cluster *
recursive-include deploy/operator *
recursive-include deploy/serverless *
recursive-include deploy/remote *
recursive-include deploy/remote-scale *
recursive-include deploy/cloud *
global-exclude *.py[cod]
global-exclude *.tfstate *.tfstate.* *.tfplan
prune benchmarks/data
prune deploy/cloud/gcp-managed-serverless/.terraform
prune deploy/cloud/gcp-remote-active-active/.terraform
