    "commands": [
      {
        "phase": "preflight",
        "name": "verify required environment",
        "command": "test -n \"${WAVEMIND_POSTGRES_DSN}\" && test -n \"${WAVEMIND_POSTGRES_BASEBACKUP_DIR}\" && test -n \"${WAVEMIND_POSTGRES_WAL_ARCHIVE_DIR}\" && test -n \"${WAVEMIND_POSTGRES_RESTORE_DATA_DIR}\" && test -n \"${WAVEMIND_POSTGRES_RESTORE_TARGET_TIME}\"",
        "validates": [
          "required_env_present"
        ],
        "destructive": false
      },
      {
        "phase": "configure",
        "name": "enable WAL archiving",
        "command": "psql \"${WAVEMIND_POSTGRES_DSN}\" -c \"ALTER SYSTEM SET wal_level = 'replica';\" -c \"ALTER SYSTEM SET archive_mode = 'on';\" -c \"ALTER SYSTEM SET archive_command = 'test ! -f ${WAVEMIND_POSTGRES_WAL_ARCHIVE_DIR}/%f && cp %p ${WAVEMIND_POSTGRES_WAL_ARCHIVE_DIR}/%f';\" -c \"SELECT pg_reload_conf();\"",
        "validates": [
          "wal_archiving_enabled"
        ],
        "destructive": false
      },
      {
        "phase": "backup",
        "name": "create streaming base backup",
        "command": "pg_basebackup --dbname \"${WAVEMIND_POSTGRES_DSN}\" --pgdata \"${WAVEMIND_POSTGRES_BASEBACKUP_DIR}\" --format=tar --gzip --wal-method=stream --checkpoint=fast --label=wavemind-basebackup",
        "validates": [
          "base_backup_created",
          "wal_streamed_with_backup"
        ],
        "destructive": false
      },
      {
        "phase": "restore",
        "name": "extract base backup into restore data directory",
        "command": "mkdir -p \"${WAVEMIND_POSTGRES_RESTORE_DATA_DIR}\" && tar -xzf \"${WAVEMIND_POSTGRES_BASEBACKUP_DIR}/base.tar.gz\" -C \"${WAVEMIND_POSTGRES_RESTORE_DATA_DIR}\"",
        "validates": [
          "base_backup_restored"
        ],
        "destructive": true
      },
      {
        "phase": "restore",
        "name": "write recovery target config",
        "command": "printf \"%s\\n\" \"restore_command = 'cp ${WAVEMIND_POSTGRES_WAL_ARCHIVE_DIR}/%f %p'\" \"recovery_target_time = '${WAVEMIND_POSTGRES_RESTORE_TARGET_TIME}'\" \"recovery_target_action = 'pause'\" >> \"${WAVEMIND_POSTGRES_RESTORE_DATA_DIR}/postgresql.auto.conf\" && touch \"${WAVEMIND_POSTGRES_RESTORE_DATA_DIR}/recovery.signal\"",
        "validates": [
          "recovery_signal_present",
          "restore_target_time_configured"
        ],
        "destructive": false
      },
      {
        "phase": "verify",
        "name": "verify replay target before promotion",
        "command": "pg_ctl start -D \"${WAVEMIND_POSTGRES_RESTORE_DATA_DIR}\" && psql \"${WAVEMIND_POSTGRES_DSN}\" -c \"SELECT pg_is_in_recovery();\" && psql \"${WAVEMIND_POSTGRES_DSN}\" -c \"SELECT pg_last_wal_replay_lsn();\"",
        "validates": [
          "restore_started",
          "wal_replay_observable"
        ],
        "destructive": false
      },
      {
        "phase": "promote",
        "name": "promote restored database after validation",
        "command": "psql \"${WAVEMIND_POSTGRES_DSN}\" -c \"SELECT pg_promote(wait_seconds => 60);\"",
        "validates": [
          "promotion_completed"
        ],
        "destructive": false
      }
    ],
    "verification_queries": [
      "SELECT pg_is_in_recovery();",
