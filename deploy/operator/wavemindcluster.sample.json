{
  "apiVersion": "memory.wavemind.ai/v1alpha1",
  "kind": "WaveMindCluster",
  "metadata": {
    "name": "wavemind",
    "namespace": "wavemind-system"
  },
  "spec": {
    "image": "ghcr.io/caspiang/wavemind:2.4.24",
    "replicas": 3,
    "replicationFactor": 2,
    "namespaceCount": 4096,
    "namespacePrefix": "tenant",
    "persistence": {
      "size": "20Gi"
    },
    "service": {
      "port": 8000
    },
    "runtime": {
      "encoder": "hash",
      "index": "faiss-persisted",
      "scoreThreshold": 0.0,
      "auditQueries": true
    },
    "cache": {
      "capacity": 512,
      "ttlSeconds": 60.0
    },
    "repair": {
      "enabled": true,
      "schedule": "*/15 * * * *",
      "limit": 1000
    },
    "controlPlane": {
      "consensus": {
        "enabled": true,
        "leaseTtlSeconds": 30.0,
        "configRevision": 0
      }
    },
    "autoscaling": {
      "enabled": true,
      "minReplicas": 3,
      "maxReplicas": 24,
      "targetCPUUtilizationPercentage": 70,
      "targetMemoryUtilizationPercentage": 80,
      "targetMemories": 10000000,
      "maxMemoriesPerNode": 1000000,
      "headroom": 0.7
    },
    "resources": {
      "requests": {
        "cpu": "500m",
        "memory": "1Gi"
      },
      "limits": {
        "cpu": "2",
        "memory": "4Gi"
      }
    }
  }
}
